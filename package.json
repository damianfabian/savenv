{
  "name": "hidevars",
  "version": "1.1.0",
  "description": "Manage project environment variables with at-rest encryption of secret values.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/adapters/vite.d.ts",
      "default": "./dist/adapters/vite.js"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/damianfabian/hidevars.git"
  },
  "bin": {
    "hidevars": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "workspaces": [
    "integrations/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "npm run build && vitest run --config vitest.integration.config.ts",
    "pack:check": "npm pack --dry-run",
    "prepack": "npm run clean && npm run build",
    "prepare": "husky || true",
    "prepublishOnly": "npm run clean && npm run build && npm test"
  },
  "keywords": [
    "env",
    "dotenv",
    "secrets",
    "encryption",
    "cli",
    "environment-variables"
  ],
  "author": "Fabian Jaramillo",
  "license": "ISC",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "husky": "^9.1.7",
    "semantic-release": "^24.2.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.10.1",
    "commander": "^14.0.3"
  },
  "peerDependencies": {
    "vite": ">=4"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  }
}
